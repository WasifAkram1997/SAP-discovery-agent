# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# LangSmith (optional for tracing)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_key_here
LANGSMITH_PROJECT="sap-discovery"

# Web Search (Serper API)
SERPER_API_KEY=your_serper_api_key_here

# Database URLs
LANGGRAPH_DATABASE_URL=postgresql://postgres:your_password@localhost:5432/sap_discovery
SESSION_DATABASE_URL=postgresql://postgres:your_password@localhost:5432/sap_discovery
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/sap_discovery
